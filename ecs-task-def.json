{
  "family": "loanms-prod",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::664418956749:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::664418956749:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "loanms-api",
      "image": "664418956749.dkr.ecr.ap-south-1.amazonaws.com/loanms:latest",
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        { "name": "ASPNETCORE_ENVIRONMENT", "value": "Production" },
        { "name": "Database__Provider",     "value": "postgresql" },
        { "name": "Redis__Enabled",         "value": "false" },
        { "name": "AI__Enabled",            "value": "false" }
      ],
      "secrets": [
        {
          "name": "ASPNETCORE_Jwt__Key",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:664418956749:secret:loanms/prod/jwt-key:JwtKey::"
        },
        {
          "name": "ConnectionStrings__PostgreSQL",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:664418956749:secret:loanms/prod/db:ConnectionString::"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8080/health || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/loanms-prod",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
